# Optional explicit config path. For local usage the app also auto-detects
# ./config/config.local.yaml and then ./config/config.yaml.
MONITOR_CONFIG=./config/config.local.yaml

# Shared OpenAI-compatible chat/dedup model key.
OPENAI_API_KEY=

# Optional separate embedding endpoint key.
# Leave empty when your embedding endpoint does not require authentication.
EMBEDDING_API_KEY=

# Optional dedicated TTS key when provider requires one.
TTS_API_KEY=

# Optional remote API token. Not needed for local-only 127.0.0.1 usage.
MONITOR_API_TOKEN=

# Telegram outbound / inbound.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# DingTalk outbound / inbound.
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ALLOWED_SENDER_IDS=
DINGTALK_ALLOWED_CONVERSATION_IDS=

# Optional behavior flags.
ENABLE_GTTS_FALLBACK=false
MONITOR_ALLOW_USER_INPUT_PLAYWRIGHT=false
